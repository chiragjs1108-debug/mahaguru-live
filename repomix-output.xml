<file path="app/api/revalidate/route.ts">
import { revalidatePath } from 'next/cache';
import { NextRequest, NextResponse } from 'next/server';

export async function POST(req: NextRequest) {
  try {
    // 1. Check for the secure secret key in the headers
    const secret = req.headers.get('x-revalidation-secret');

    // This must match your .env.local password AND your n8n Node 6 header
    if (secret !== process.env.REVALIDATION_SECRET) {
      return NextResponse.json({ message: 'Unauthorized: Invalid secret token' }, { status: 401 });
    }

    // 2. Parse the incoming request from n8n
    const body = await req.json();
    const { slug } = body;

    // 3. Clear the cache for the main Articles Hub
    revalidatePath('/articles');
    
    // 4. Clear the cache for the Homepage (since it displays the Latest Articles)
    revalidatePath('/');

    // 5. If n8n passed a specific slug, clear the cache for that exact article
    if (slug) {
      revalidatePath(`/articles/${slug}`);
    }

    return NextResponse.json({ 
      revalidated: true, 
      now: Date.now(),
      message: `Successfully flushed cache for ${slug ? slug : 'main feeds'}`
    });

  } catch (err) {
    console.error('Revalidation error:', err);
    return NextResponse.json({ message: 'Internal Server Error during revalidation' }, { status: 500 });
  }
}
